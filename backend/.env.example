OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
DATABASE_URL=sqlite+aiosqlite:///./db/history.db
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_UPLOAD_MB=50
EXEC_TIMEOUT=30
CORS_ORIGINS=http://localhost:5173

REFLECTION_ENABLED=true
REFLECTION_MAX_STEPS=3
TOOLS_DIR=./tools

DEBUG_LOOP_ENABLED=true
DEBUG_RETRY_LIMIT=3

SKILLS_ENABLED=true
SKILLS_DIR=./skills
SKILLS_SIMILARITY_THRESHOLD=0.4
