# =============================================================================
# ToolBuilder — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# At least one LLM provider is required.

# -----------------------------------------------------------------------------
# LLM Providers (set at least one)
# -----------------------------------------------------------------------------

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (API key — billed per token)
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Claude Agent SDK (subscription-based — uses OAuth token from Claude Code)
# Get token: cat ~/.claude/.credentials.json | jq -r '.claudeAiOauth.accessToken'
CLAUDE_CODE_OAUTH_TOKEN=

# Provider-agnostic model override (takes precedence over OPENAI_MODEL)
# Examples: gpt-4o, anthropic/claude-sonnet-4-6, ollama/gemma4:e4b, claude-sdk/claude-sonnet-4-6
LLM_MODEL=
LLM_BASE_URL=

# -----------------------------------------------------------------------------
# Database & Storage
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./db/history.db
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_UPLOAD_MB=50
EXEC_TIMEOUT=30
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
